= form_with model: subject, url: (subject.persisted? ? admin_subject_path(subject) : admin_subjects_path), class: "space-y-4 bg-white border border-gray-200 rounded-lg p-6" do |f|
  - if subject.errors.any?
    .bg-red-50.border.border-red-200.text-red-800.rounded.p-3.text-sm
      %ul.list-disc.pl-5
        - subject.errors.full_messages.each do |msg|
          %li= msg

  %div
    = f.label :name, class: "block text-sm font-medium mb-1"
    = f.text_field :name, class: "w-full border border-gray-300 rounded px-3 py-2"
  %div
    = f.label :description, class: "block text-sm font-medium mb-1"
    = f.text_area :description, rows: 4, class: "w-full border border-gray-300 rounded px-3 py-2"
  %div
    = f.label :slug, "Slug (leave blank to auto-generate)", class: "block text-sm font-medium mb-1"
    = f.text_field :slug, class: "w-full border border-gray-300 rounded px-3 py-2"
  .flex.w-full.gap-2
    = f.submit class: "flex-1 px-4 py-2 rounded bg-indigo-600 text-white hover:bg-indigo-700 cursor-pointer text-center"
    = link_to "Cancel", admin_subjects_path, class: "px-4 py-2 rounded border border-amber-300 bg-amber-100 text-amber-800 hover:bg-amber-200 text-center"
