- content_for :title, "Subjects"

.flex.items-center.justify-between.mb-4
  %h1.text-2xl.font-bold Subjects
  = link_to "New subject", new_admin_subject_path, class: "inline-flex items-center px-3 py-1.5 rounded-full text-sm font-medium bg-indigo-600 text-white hover:bg-indigo-700 transition-colors"

%table.w-full.bg-white.border.border-gray-200.rounded
  %thead.bg-gray-50
    %tr
      %th.text-left.text-xs.font-medium.text-gray-500.px-3.py-2 Name
      %th.text-left.text-xs.font-medium.text-gray-500.px-3.py-2 Slug
      %th.text-left.text-xs.font-medium.text-gray-500.px-3.py-2 Courses
      %th.text-right.text-xs.font-medium.text-gray-500.px-3.py-2
  %tbody
    - @subjects.each do |s|
      %tr.border-t.border-gray-100
        %td.px-3.py-2.font-medium= s.name
        %td.px-3.py-2.text-sm.text-gray-600= s.slug
        %td.px-3.py-2
          = link_to admin_courses_path(subject_id: s.id), class: "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 hover:bg-blue-200 transition-colors", title: "View courses in #{s.name}" do
            = s.courses.count
        %td.px-3.py-2.text-right
          .flex.flex-wrap.justify-end.gap-2
            = link_to "Edit", edit_admin_subject_path(s), class: "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 hover:bg-gray-200 border border-gray-200 transition-colors"
            = button_to "Delete", admin_subject_path(s), method: :delete, data: { turbo_confirm: "Delete subject?" }, class: "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800 hover:bg-red-200 cursor-pointer transition-colors"
