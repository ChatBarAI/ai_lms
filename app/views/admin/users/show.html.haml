- content_for :title, @user.email

.flex.items-center.justify-between.mb-4
  %div
    %h1.text-2xl.font-bold= @user.email
    .text-sm.text-gray-500
      = @user.role.to_s.humanize
      - if @user.organization
        · #{link_to @user.organization.name, admin_organization_path(@user.organization), class: "text-indigo-600 hover:underline"}
  .flex.gap-2
    = link_to "Edit", edit_admin_user_path(@user), class: "px-3 py-1.5 rounded bg-gray-100 text-gray-800 hover:bg-gray-200 border border-gray-200 text-sm"
    = button_to "Send password reset", reset_password_admin_user_path(@user), method: :post, class: "px-3 py-1.5 rounded bg-amber-100 text-amber-800 hover:bg-amber-200 border border-amber-200 text-sm cursor-pointer"
    - if @user != current_user
      = button_to "Delete", admin_user_path(@user), method: :delete, data: { turbo_confirm: "Delete #{@user.email}?" }, class: "px-3 py-1.5 rounded bg-red-100 text-red-800 hover:bg-red-200 border border-red-200 text-sm cursor-pointer"

.grid.grid-cols-2.md:grid-cols-4.gap-3.mb-6
  - tiles = [ [ "Enrolments", @enrollments.size ], [ "Lessons done", @user.completed_lessons_count ], [ "Avg score", (@user.average_score&.round(1) || "—") ], [ "Last activity", @user.last_activity_at&.strftime("%Y-%m-%d") || "—" ] ]
  - tiles.each do |label, value|
    .bg-white.border.border-gray-200.rounded.p-3
      .text-xs.uppercase.tracking-wide.text-gray-500= label
      .text-2xl.font-semibold.mt-1= value

.grid.grid-cols-1.lg:grid-cols-3.gap-4
  .lg:col-span-2.space-y-4
    .bg-white.border.border-gray-200.rounded
      .px-4.py-2.border-b.border-gray-100.font-semibold Enrolments
      - if @enrollments.any?
        %table.w-full.text-sm
          %thead.bg-gray-50
            %tr
              %th.text-left.text-xs.font-medium.text-gray-500.px-3.py-2 Course
              %th.text-right.text-xs.font-medium.text-gray-500.px-3.py-2 Progress
              %th.text-right.text-xs.font-medium.text-gray-500.px-3.py-2 Avg score
              %th.text-left.text-xs.font-medium.text-gray-500.px-3.py-2 Enrolled
              %th.text-left.text-xs.font-medium.text-gray-500.px-3.py-2 Last activity
          %tbody
            - @enrollments.each do |e|
              %tr.border-t.border-gray-100
                %td.px-3.py-2= link_to e.course.title, admin_course_path(e.course), class: "text-indigo-600 hover:underline"
                %td.px-3.py-2.text-right #{e.completion_percentage}%
                %td.px-3.py-2.text-right= e.average_score&.round(1) || "—"
                %td.px-3.py-2.text-gray-500= e.enrolled_at&.strftime("%Y-%m-%d") || "—"
                %td.px-3.py-2.text-gray-500= e.last_progress_at&.strftime("%Y-%m-%d") || "—"
      - else
        .px-4.py-3.text-sm.text-gray-500 No enrolments yet.

    .bg-white.border.border-gray-200.rounded
      .px-4.py-2.border-b.border-gray-100.font-semibold Recent lesson completions
      - if @recent_completions.any?
        %ul.divide-y.divide-gray-100
          - @recent_completions.each do |p|
            %li.px-4.py-2.text-sm.flex.justify-between
              %span= p.lesson&.title
              %span.text-gray-500= p.completed_at&.strftime("%Y-%m-%d %H:%M")
      - else
        .px-4.py-3.text-sm.text-gray-500 No completions yet.

    .bg-white.border.border-gray-200.rounded
      .px-4.py-2.border-b.border-gray-100.font-semibold Ratings given
      - if @ratings_given.any?
        %ul.divide-y.divide-gray-100
          - @ratings_given.each do |r|
            %li.px-4.py-2.text-sm.flex.justify-between
              %span= r.lesson&.title
              %span.text-amber-600 #{r.stars}★
      - else
        .px-4.py-3.text-sm.text-gray-500 No ratings yet.

  .space-y-4
    .bg-white.border.border-gray-200.rounded.p-4
      .font-semibold.mb-2 Force-enrol in course
      = form_with url: enroll_admin_user_path(@user), method: :post, local: true, class: "space-y-2" do
        = select_tag :course_id, options_from_collection_for_select(@enrollable_courses, :id, :title), class: "w-full border border-gray-300 rounded px-2 py-1.5 text-sm bg-white"
        = submit_tag "Enrol", class: "w-full px-3 py-1.5 rounded bg-indigo-600 text-white text-sm hover:bg-indigo-700 cursor-pointer"

    .bg-white.border.border-gray-200.rounded.p-4.text-sm.text-gray-600
      .font-semibold.text-gray-800.mb-2 Account
      %dl.space-y-1
        %dt.text-xs.uppercase.tracking-wide.text-gray-500 Created
        %dd= @user.created_at.strftime("%Y-%m-%d")
        %dt.text-xs.uppercase.tracking-wide.text-gray-500.mt-2 Sign-in count
        %dd= @user.sign_in_count
        %dt.text-xs.uppercase.tracking-wide.text-gray-500.mt-2 Current sign-in IP
        %dd= @user.current_sign_in_ip || "—"
        %dt.text-xs.uppercase.tracking-wide.text-gray-500.mt-2 Locked?
        %dd= @user.access_locked? ? "Yes" : "No"
