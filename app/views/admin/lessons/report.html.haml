- content_for :title, "#{@lesson.title} – Report"

.flex.items-center.justify-between.mb-4
  %div
    %h1.text-2xl.font-bold= @lesson.title
    .text-sm.text-gray-500
      Lesson report ·
      = link_to @course.title, admin_course_path(@course), class: "text-indigo-600 hover:underline"
  = link_to "Back to course report", report_admin_course_path(@course), class: "px-3 py-1.5 rounded bg-gray-100 text-gray-800 hover:bg-gray-200 border border-gray-200 text-sm"

.grid.grid-cols-2.md:grid-cols-5.gap-3.mb-6
  - tiles = [ [ "Attempts", @attempts ], [ "Completions", @completions ], [ "Avg score", @average_score&.round(1) || "—" ], [ "Pass rate", @pass_rate ? "#{@pass_rate}%" : "—" ], [ "Avg rating", @average_rating&.round(2) || "—" ] ]
  - tiles.each do |label, value|
    .bg-white.border.border-gray-200.rounded.p-3
      .text-xs.uppercase.tracking-wide.text-gray-500= label
      .text-2xl.font-semibold.mt-1= value

.grid.grid-cols-1.lg:grid-cols-2.gap-4.mb-6
  .bg-white.border.border-gray-200.rounded.p-4
    %h2.font-semibold.mb-2 Completions per week (12w)
    = svg_chart @completions_per_week, type: :column, color: "#16a34a"
  .bg-white.border.border-gray-200.rounded.p-4
    %h2.font-semibold.mb-2 Ratings distribution
    - if @ratings_distribution.any?
      = svg_chart @ratings_distribution.sort.to_h, type: :column, color: "#f59e0b"
    - else
      .text-sm.text-gray-500 No ratings yet.

.grid.grid-cols-1.lg:grid-cols-2.gap-4
  .bg-white.border.border-gray-200.rounded
    .px-4.py-2.border-b.border-gray-100.font-semibold Recent attempts
    - if @recent_attempts.any?
      %table.w-full.text-sm
        %thead.bg-gray-50
          %tr
            %th.text-left.text-xs.font-medium.text-gray-500.px-3.py-2 User
            %th.text-left.text-xs.font-medium.text-gray-500.px-3.py-2 Status
            %th.text-right.text-xs.font-medium.text-gray-500.px-3.py-2 Score
            %th.text-left.text-xs.font-medium.text-gray-500.px-3.py-2 Updated
        %tbody
          - @recent_attempts.each do |p|
            %tr.border-t.border-gray-100
              %td.px-3.py-2= link_to p.enrollment.user.email, admin_user_path(p.enrollment.user), class: "text-indigo-600 hover:underline"
              %td.px-3.py-2= p.status.humanize
              %td.px-3.py-2.text-right= p.score || "—"
              %td.px-3.py-2.text-gray-500= p.updated_at.strftime("%Y-%m-%d %H:%M")
    - else
      .px-4.py-3.text-sm.text-gray-500 No attempts yet.

  .bg-white.border.border-gray-200.rounded
    .px-4.py-2.border-b.border-gray-100.font-semibold Recent comments
    - if @recent_comments.any?
      %ul.divide-y.divide-gray-100
        - @recent_comments.each do |r|
          %li.px-4.py-3.text-sm
            .flex.justify-between
              %span.font-medium= r.user.email
              %span.text-amber-600 #{r.stars}★
            .text-gray-600.mt-1= r.comment
    - else
      .px-4.py-3.text-sm.text-gray-500 No comments yet.

- if @ai_answers.any?
  .mt-4.bg-white.border.border-gray-200.rounded
    .px-4.py-2.border-b.border-gray-100.flex.items-center.justify-between
      %span.font-semibold ChatBar AI lesson marking
      - pending = @ai_answers.count { |a| a.ai_score.nil? }
      - if pending > 0
        .flex.items-center.gap-1.5
          .w-2.h-2.rounded-full.bg-indigo-500.animate-pulse
          %span.text-xs.text-indigo-600.font-medium= "#{pending} pending"
    %table.w-full.text-sm.table-fixed
      %thead.bg-gray-50
        %tr
          %th.text-left.text-xs.font-medium.text-gray-500.px-3.py-2{ style: "width:16%" } Student
          %th.text-left.text-xs.font-medium.text-gray-500.px-3.py-2{ style: "width:24%" } Question
          %th.text-left.text-xs.font-medium.text-gray-500.px-3.py-2{ style: "width:22%" } Their answer
          %th.text-left.text-xs.font-medium.text-gray-500.px-3.py-2{ style: "width:22%" } Expected
          %th.text-center.text-xs.font-medium.text-gray-500.px-3.py-2{ style: "width:8%" } Score
          %th.text-left.text-xs.font-medium.text-gray-500.px-3.py-2{ style: "width:8%" } Scored at
      %tbody
        - @ai_answers.each do |qa|
          %tr.border-t.border-gray-100
            %td.px-3.py-2.text-gray-700.truncate{ title: qa.user_email }= qa.user_email
            %td.px-3.py-2.text-gray-700.truncate{ title: qa.question_body }= qa.question_body
            %td.px-3.py-2.text-gray-700.truncate{ title: qa.answer_text }= qa.answer_text.presence || "—"
            %td.px-3.py-2.text-gray-500.truncate{ title: qa.expected_answer }= qa.expected_answer.presence || "—"
            %td.px-3.py-2.text-center
              - if qa.ai_score
                %span.inline-flex.items-center.rounded-full.px-2.py-0.5.text-xs.font-semibold{ class: qa.ai_score >= 7 ? "bg-green-100 text-green-800" : qa.ai_score >= 4 ? "bg-amber-100 text-amber-800" : "bg-red-100 text-red-800" }
                  = "#{qa.ai_score}/10"
              - else
                %span.text-xs.text-indigo-500 pending
            %td.px-3.py-2.text-gray-400.text-xs.truncate{ title: qa.scored_at&.strftime("%Y-%m-%d %H:%M") }= qa.scored_at&.strftime("%Y-%m-%d %H:%M") || "—"
