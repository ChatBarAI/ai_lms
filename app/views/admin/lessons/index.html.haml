- content_for :title, "Lessons — #{@course.title}"

.flex.items-center.justify-between.mb-4
  .flex.items-baseline.gap-4
    %h1.text-2xl.font-bold Lessons
    %p.text-sm.text-gray-500.mt-1
      Course:
      = link_to @course.title, admin_courses_path, class: "text-indigo-600 hover:underline"
  = link_to "Add lesson", new_course_lesson_path(@course), class: "inline-flex items-center px-3 py-1.5 rounded-full text-sm font-medium bg-indigo-600 text-white hover:bg-indigo-700 transition-colors"

- if @lessons.empty?
  %p.text-gray-500.text-sm This course has no lessons yet.
- else
  %table.w-full.bg-white.border.border-gray-200.rounded
    %thead.bg-gray-50
      %tr
        %th.text-left.text-xs.font-medium.text-gray-500.px-3.py-2 #
        %th.text-left.text-xs.font-medium.text-gray-500.px-3.py-2 Title
        %th.text-left.text-xs.font-medium.text-gray-500.px-3.py-2 Questions
        %th.text-left.text-xs.font-medium.text-gray-500.px-3.py-2 Materials
        %th.text-left.text-xs.font-medium.text-gray-500.px-3.py-2 Status
        %th.text-right.text-xs.font-medium.text-gray-500.px-3.py-2
    %tbody
      - @lessons.each do |lesson|
        %tr.border-t.border-gray-100
          %td.px-3.py-2.text-sm.text-gray-500= lesson.position
          %td.px-3.py-2.font-medium= lesson.title
          %td.px-3.py-2.text-sm.text-gray-600
            = link_to lesson.questions.size, course_lesson_questions_path(@course, lesson), class: "font-medium text-indigo-600 hover:text-indigo-800 hover:underline"
          %td.px-3.py-2.text-sm.text-gray-600
            = link_to lesson.lesson_materials.size, course_lesson_lesson_materials_path(@course, lesson), class: "font-medium text-indigo-600 hover:text-indigo-800 hover:underline"
          %td.px-3.py-2.text-sm
            %span{ class: "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium #{lesson.published? ? 'bg-green-100 text-green-800' : 'bg-amber-100 text-amber-800'}" }
              = lesson.published? ? "published" : "draft"
          %td.px-3.py-2.text-right
            .flex.flex-wrap.justify-end.gap-2
              = link_to "View", course_lesson_path(@course, lesson), class: "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 hover:bg-gray-200 border border-gray-200 transition-colors"
              = link_to "Report", report_admin_course_lesson_path(@course, lesson), class: "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-50 text-indigo-700 hover:bg-indigo-100 border border-indigo-100 transition-colors"
              = link_to "Edit", edit_course_lesson_path(@course, lesson), class: "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 hover:bg-gray-200 border border-gray-200 transition-colors"
