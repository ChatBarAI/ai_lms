- content_for :title, "Courses"

.flex.items-center.justify-between.mb-4
  %div
    %h1.text-2xl.font-bold Courses
    - if subjects_enabled? && @selected_subject
      %p.text-sm.text-gray-500.mt-1= "Filtered by subject: #{@selected_subject.name}"
  .flex.items-center.gap-2
    = link_to "Export CSV", admin_courses_path(request.query_parameters.merge(format: :csv)), class: "inline-flex items-center px-3 py-1.5 rounded-full text-sm font-medium bg-gray-100 text-gray-800 hover:bg-gray-200 border border-gray-200"
    = link_to "New course", new_admin_course_path, class: "inline-flex items-center px-3 py-1.5 rounded-full text-sm font-medium bg-indigo-600 text-white hover:bg-indigo-700 transition-colors"

%table.w-full.bg-white.border.border-gray-200.rounded
  %thead.bg-gray-50
    %tr
      %th.text-left.text-xs.font-medium.text-gray-500.px-3.py-2{ title: "The course title shown to learners and administrators." } Title
      - if subjects_enabled?
        %th.text-left.text-xs.font-medium.text-gray-500.px-3.py-2{ title: "The subject this course is grouped under." } Subject
      %th.text-left.text-xs.font-medium.text-gray-500.px-3.py-2{ title: "The language used for this course." } Language
      %th.text-left.text-xs.font-medium.text-gray-500.px-3.py-2{ title: "The instructor or administrator who owns this course." } Owner
      %th.text-left.text-xs.font-medium.text-gray-500.px-3.py-2{ title: "Shows whether this course is published or still a draft." } Status
      %th.text-left.text-xs.font-medium.text-gray-500.px-3.py-2{ title: "Displays when a Course and Lessons are publicly viewable without sign in." } Access
      %th.text-center.text-xs.font-medium.text-gray-500.px-3.py-2{ title: "The number of lessons in this course." } Lessons
      %th.text-right.text-xs.font-medium.text-gray-500.px-3.py-2{ title: "Available actions for this course." }
  %tbody
    - @courses.each do |c|
      %tr.border-t.border-gray-100
        %td.px-3.py-2.font-medium= c.title
        - if subjects_enabled?
          %td.px-3.py-2.text-sm.text-gray-600= c.subject&.name
        %td.px-3.py-2.text-sm.text-gray-600= User::SUPPORTED_LOCALES.fetch(c.locale, c.locale)
        %td.px-3.py-2.text-sm.text-gray-600= c.owner&.email
        %td.px-3.py-2.text-sm
          %span{ class: "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium #{c.published? ? 'bg-green-100 text-green-800' : 'bg-amber-100 text-amber-800'}" }= c.published? ? "published" : "draft"
        %td.px-3.py-2.text-sm
          - if c.public_access_enabled?
            %span.inline-flex.items-center.px-2.5.py-0.5.rounded-full.text-xs.font-medium.bg-sky-100.text-sky-800 Public
          - else
            %span.text-xs.text-gray-400 —
        %td.px-3.py-2.text-center.text-sm
          = link_to c.lessons.size, admin_course_lessons_path(c), class: "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-50 text-indigo-700 hover:bg-indigo-100 border border-indigo-100 transition-colors"
        %td.px-3.py-2.text-right
          .flex.flex-wrap.justify-end.gap-2
            = link_to "View", course_path(c), class: "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 hover:bg-gray-200 border border-gray-200 transition-colors"
            = link_to "Report", report_admin_course_path(c), class: "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-50 text-indigo-700 hover:bg-indigo-100 border border-indigo-100 transition-colors"
            = link_to "Edit", edit_admin_course_path(c), class: "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 hover:bg-gray-200 border border-gray-200 transition-colors"
            = button_to "Delete", admin_course_path(c), method: :delete, data: { turbo_confirm: "Delete?" }, class: "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800 hover:bg-red-200 cursor-pointer transition-colors"
