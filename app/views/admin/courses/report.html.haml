- content_for :title, "#{@course.title} – Report"

.flex.items-center.justify-between.mb-4
  %div
    %h1.text-2xl.font-bold #{@course.title}
    .text-sm.text-gray-500 Course report
  = link_to "Back to course", admin_course_path(@course), class: "px-3 py-1.5 rounded bg-gray-100 text-gray-800 hover:bg-gray-200 border border-gray-200 text-sm"

.grid.grid-cols-2.md:grid-cols-5.gap-3.mb-6
  - tiles = [ [ "Enrolments", @enrollment_count ], [ "Active learners", @active_learners ], [ "Completion rate", "#{@completion_rate}%" ], [ "Avg score", @average_score&.round(1) || "—" ], [ "Avg rating", @average_rating&.round(2) || "—" ] ]
  - tiles.each do |label, value|
    .bg-white.border.border-gray-200.rounded.p-3
      .text-xs.uppercase.tracking-wide.text-gray-500= label
      .text-2xl.font-semibold.mt-1= value

.grid.grid-cols-1.lg:grid-cols-2.gap-4.mb-6
  .bg-white.border.border-gray-200.rounded.p-4
    %h2.font-semibold.mb-2 Enrolments per week (12w)
    = svg_chart @enrollments_per_week, type: :column, color: "#0ea5e9"
  .bg-white.border.border-gray-200.rounded.p-4
    %h2.font-semibold.mb-2 Completions per week (12w)
    = svg_chart @completions_per_week, type: :column, color: "#16a34a"
  .bg-white.border.border-gray-200.rounded.p-4.lg:col-span-2
    %h2.font-semibold.mb-2 Score distribution
    - if @score_distribution.any?
      = svg_chart @score_distribution, type: :column, color: "#6366f1"
    - else
      .text-sm.text-gray-500 No scored attempts yet.

.bg-white.border.border-gray-200.rounded.mb-6
  .px-4.py-2.border-b.border-gray-100.font-semibold Top learners
  - if @top_learners.any?
    %table.w-full.text-sm
      %thead.bg-gray-50
        %tr
          %th.text-left.text-xs.font-medium.text-gray-500.px-3.py-2 User
          %th.text-right.text-xs.font-medium.text-gray-500.px-3.py-2 Completed
          %th.text-right.text-xs.font-medium.text-gray-500.px-3.py-2 Avg score
          %th.text-left.text-xs.font-medium.text-gray-500.px-3.py-2 Last activity
      %tbody
        - @top_learners.each do |e|
          %tr.border-t.border-gray-100
            %td.px-3.py-2= link_to e.user.email, admin_user_path(e.user), class: "text-indigo-600 hover:underline"
            %td.px-3.py-2.text-right= e.lessons_completed_count
            %td.px-3.py-2.text-right= e.average_score&.round(1) || "—"
            %td.px-3.py-2.text-gray-500= e.last_progress_at&.strftime("%Y-%m-%d") || "—"
  - else
    .px-4.py-3.text-sm.text-gray-500 No enrolments yet.

.bg-white.border.border-gray-200.rounded
  .px-4.py-2.border-b.border-gray-100.font-semibold Per-lesson summary
  %table.w-full.text-sm
    %thead.bg-gray-50
      %tr
        %th.text-left.text-xs.font-medium.text-gray-500.px-3.py-2 Lesson
        %th.text-right.text-xs.font-medium.text-gray-500.px-3.py-2 Attempts
        %th.text-right.text-xs.font-medium.text-gray-500.px-3.py-2 Completions
        %th.text-right.text-xs.font-medium.text-gray-500.px-3.py-2 Avg score
        %th.text-right.text-xs.font-medium.text-gray-500.px-3.py-2 Pass rate
        %th.text-right.text-xs.font-medium.text-gray-500.px-3.py-2 Avg rating
        %th.text-right.text-xs.font-medium.text-gray-500.px-3.py-2
    %tbody
      - @lesson_summary.each do |row|
        %tr.border-t.border-gray-100
          %td.px-3.py-2= row[:lesson].title
          %td.px-3.py-2.text-right= row[:attempts]
          %td.px-3.py-2.text-right= row[:completions]
          %td.px-3.py-2.text-right= row[:average_score]&.round(1) || "—"
          %td.px-3.py-2.text-right= row[:pass_rate] ? "#{row[:pass_rate]}%" : "—"
          %td.px-3.py-2.text-right= row[:average_rating]&.round(2) || "—"
          %td.px-3.py-2.text-right
            = link_to "Report", report_admin_course_lesson_path(@course, row[:lesson]), class: "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-50 text-indigo-700 hover:bg-indigo-100 border border-indigo-100"
