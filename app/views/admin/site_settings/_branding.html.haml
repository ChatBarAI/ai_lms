%section{ id: "branding", class: "scroll-mt-24", data: { site_settings_section: "branding" } }
  = form_with model: @site_setting, url: admin_site_setting_path, method: :patch, data: { turbo: false }, class: "rounded-xl border border-gray-200 bg-white p-6 shadow-sm" do |f|
    = hidden_field_tag :section, "branding"

    .flex.items-start.justify-between.gap-4
      %div
        %h2.text-lg.font-semibold.text-gray-900 Branding
        %p.text-sm.text-gray-500 Brand identity across navigation and social cards.

    = render "section_errors", section: "branding"

    .mt-5.grid.grid-cols-1.gap-6.lg:grid-cols-2
      .space-y-5
        %div
          = f.label :brand_name, class: "block text-sm font-medium mb-1"
          = f.text_field :brand_name, class: "w-full border border-gray-300 rounded px-3 py-2"
          %p.text-xs.text-gray-500.mt-1 Shown next to the logo in the top navigation.

        = toggle_switch_field f, :show_brand_name,
            label: "Display brand name next to the logo"

        = toggle_switch_field f, :invert_logo_on_dark,
            label: "Invert logo colours in dark mode"

        - if @site_setting.respond_to?(:has_attribute?) && @site_setting.has_attribute?(:brand_primary_color)
          %div
            = f.label :brand_primary_color, "Primary brand colour", class: "block text-sm font-medium mb-1"
            = color_field_tag :brand_primary_color_picker,
                (@site_setting[:brand_primary_color].presence || "#2563eb"),
                class: "h-10 w-16 border border-gray-300 rounded p-1 align-middle",
                onchange: "document.getElementById('site_setting_brand_primary_color').value=this.value"
            = f.text_field :brand_primary_color,
                placeholder: "#2563eb",
                class: "ml-2 inline-block w-32 border border-gray-300 rounded px-3 py-2 align-middle",
                pattern: "^#[0-9A-Fa-f]{6}$",
                oninput: "var p=document.getElementById('brand_primary_color_picker');if(p&&/^#[0-9A-Fa-f]{6}$/.test(this.value)){p.value=this.value;}"
            %p.text-xs.text-gray-500.mt-1
              Used as the app's primary PWA colour and Apple touch icon background.

        %div
          = upload_field f, :default_meta_card_image,
              label: "Upload default card image (PNG, JPG or WebP, max 5 MB)",
              accept: "image/png,image/jpeg,image/webp",
              current_attachment: @site_setting.default_meta_card_image,
              default_image_path: "default-meta-card-image.jpg",
              default_image_note: "(built-in default)",
              remove_name: "site_setting[remove_default_meta_card_image]",
              remove_label: "Remove and revert to built-in default",
              hint: "Default card image (optional)",
              preview_class: "h-20 w-auto rounded border border-gray-200 object-cover"

        %div
          = upload_field f, :pwa_screenshot_mobile,
              label: "Upload mobile install preview (PNG, JPG or WebP, max 8 MB)",
              accept: "image/png,image/jpeg,image/webp",
              current_attachment: @site_setting.pwa_screenshot_mobile,
              remove_name: "site_setting[remove_pwa_screenshot_mobile]",
              remove_label: "Remove current mobile install preview",
              hint: "Manifest screenshot (mobile, narrow)",
              preview_class: "h-24 w-auto rounded border border-gray-200 object-contain"

        %div
          = upload_field f, :pwa_screenshot_desktop,
              label: "Upload desktop install preview (PNG, JPG or WebP, max 8 MB)",
              accept: "image/png,image/jpeg,image/webp",
              current_attachment: @site_setting.pwa_screenshot_desktop,
              remove_name: "site_setting[remove_pwa_screenshot_desktop]",
              remove_label: "Remove current desktop install preview",
              hint: "Manifest screenshot (desktop, wide)",
              preview_class: "h-24 w-auto rounded border border-gray-200 object-contain"


      .space-y-5
        %div
          = upload_field f, :logo,
              label: "Upload logo (PNG, JPG, SVG or WebP, max 2 MB)",
              accept: "image/png,image/jpeg,image/svg+xml,image/webp",
              current_attachment: @site_setting.logo,
              default_image_path: "default-logo.png",
              default_image_note: "(default ChatBar AI logo)",
              remove_name: "site_setting[remove_logo]",
              remove_label: "Remove current logo and revert to default",
              preview_class: "h-12 w-auto bg-gray-100 rounded p-1 border border-gray-200"

        %div
          = upload_field f, :favicon,
              label: "Upload favicon (PNG, SVG or WebP, max 1 MB)",
              accept: "image/png,image/svg+xml,image/webp",
              current_attachment: @site_setting.favicon,
              default_image_path: "/favicon.png",
              default_image_note: "(default ChatBar AI favicon)",
              remove_name: "site_setting[remove_favicon]",
              remove_label: "Remove current favicon and revert to default",
              preview_class: "h-8 w-8 bg-gray-100 rounded p-1 border border-gray-200"

        .rounded-lg.border.border-gray-200.p-4{ style: "background-color: color-mix(in srgb, var(--card-bg) 92%, #ffffff 8%);" }
          %h3.text-sm.font-semibold.text-gray-900 PWA icon preview
          %p.mt-1.text-xs.text-gray-600
            Live preview of generated install icons, including the Apple touch icon composition.
          .mt-3.grid.max-w-2xl.grid-cols-1.gap-3.sm:grid-cols-2
            .rounded-md.border.border-gray-200.bg-white.p-3
              %p.text-xs.font-medium.text-gray-700 192x192 (any)
              .mt-2.flex.items-center.justify-center.rounded.bg-gray-100.p-3
                = image_tag pwa_icon_path(kind: "192", v: pwa_asset_version), alt: "PWA icon 192", class: "h-16 w-16 rounded"
              %p{ class: "mt-2 text-[11px] text-gray-500" } Source: #{pwa_icon_source_label(@site_setting)}
            .rounded-md.border.border-gray-200.bg-white.p-3
              %p.text-xs.font-medium.text-gray-700 512x512 (any)
              .mt-2.flex.items-center.justify-center.rounded.bg-gray-100.p-3
                = image_tag pwa_icon_path(kind: "512", v: pwa_asset_version), alt: "PWA icon 512", class: "h-20 w-20 rounded"
              %p{ class: "mt-2 text-[11px] text-gray-500" } Source: #{pwa_icon_source_label(@site_setting)}
            .rounded-md.border.border-gray-200.bg-white.p-3
              %p.text-xs.font-medium.text-gray-700 512x512 (maskable)
              .mt-2.flex.items-center.justify-center.rounded.bg-gray-100.p-3
                = image_tag pwa_icon_path(kind: "maskable-512", v: pwa_asset_version), alt: "PWA maskable icon 512", class: "h-20 w-20 rounded"
              %p{ class: "mt-2 text-[11px] text-gray-500" } Source: #{pwa_icon_source_label(@site_setting)}
            .rounded-md.border.border-gray-200.bg-white.p-3
              %p.text-xs.font-medium.text-gray-700 180x180 (apple-touch)
              .mt-2.flex.items-center.justify-center.rounded.p-3{ style: "background-color: color-mix(in srgb, #{pwa_apple_touch_background_color} 18%, #ffffff 82%);" }
                = image_tag pwa_icon_path(kind: "apple-touch", v: pwa_asset_version), alt: "Apple touch icon 180", class: "h-20 w-20", style: "border-radius: 22%;"
              %p{ class: "mt-2 text-[11px] text-gray-500" } Expected iOS home-screen appearance
          %p.mt-2.text-xs.text-gray-500
            Tip: after updating branding, save settings and reinstall the app to refresh launcher and home-screen icons.


    .mt-6.flex.items-center.gap-2.border-t.border-gray-200.pt-4
      = f.submit "Save branding", class: "px-4 py-2 rounded bg-indigo-600 text-white hover:bg-indigo-700 cursor-pointer"
