%section{ id: "integration", class: "scroll-mt-24", data: { site_settings_section: "integration" } }
  = form_with model: @site_setting, url: admin_site_setting_path, method: :patch, data: { turbo: false }, class: "rounded-xl border border-gray-200 bg-white p-6 shadow-sm" do |f|
    = hidden_field_tag :section, "integration"

    %h2.text-lg.font-semibold.text-gray-900 Integration and jobs
    %p.text-sm.text-gray-500 App callback URL plus Redis connection for background jobs and queue visibility.

    = render "section_errors", section: "integration"

    .mt-5
      = f.label :app_url, "App URL", class: "block text-sm font-medium mb-1"
      = f.url_field :app_url, placeholder: "https://yourapp.example.com", class: "w-full border border-gray-300 rounded px-3 py-2"
      %p.text-xs.text-gray-500.mt-1 Base URL used for AI task callbacks.

      - stored = @site_setting.app_url.to_s.chomp("/")
      - current = @current_base_url.to_s.chomp("/")
      - if stored.blank?
        .mt-2.rounded.border.border-amber-300.bg-amber-50.px-3.py-2.text-xs.text-amber-800
          %span.font-semibold App URL not set.
          %span.ml-1 Current request URL is #{current}.
      - elsif stored != current
        .mt-2.rounded.border.border-amber-300.bg-amber-50.px-3.py-2.text-xs.text-amber-800
          %span.font-semibold URL mismatch.
          %span.ml-1 Saved: #{stored}. Current request: #{current}.
      - else
        .mt-2.rounded.border.border-green-300.bg-green-50.px-3.py-2.text-xs.text-green-800
          %span.font-semibold URL matches current request.

    .mt-5
      = f.label :redis_url, "Redis URL", class: "block text-sm font-medium mb-1"
      = f.text_field :redis_url, placeholder: "redis://localhost:6379/0", class: "w-full border border-gray-300 rounded px-3 py-2 font-mono text-sm"
      %p.text-xs.text-gray-500.mt-1
        Include the DB number in the URL path (for example, redis://localhost:6379/2).

    .mt-4
      - if @redis_info[:error]
        .rounded.border.border-red-300.bg-red-50.px-4.py-3.text-sm.text-red-800
          %span.font-semibold Could not connect to Redis:
          = @redis_info[:error]
          %br
          %span.text-xs Configured URL:
          %code.text-xs= @redis_info[:url]
      - else
        .rounded.border.border-gray-200.bg-gray-50.px-4.py-3.text-sm.space-y-2
          .flex.flex-wrap.items-center.gap-2
            %span.font-medium.text-gray-700 REDIS_URL:
            %code.bg-white.border.border-gray-200.rounded.px-2.py-0.5.text-xs= @redis_info[:url]
          .flex.flex-wrap.items-center.gap-2
            %span.font-medium.text-gray-700 Current DB:
            %span.inline-flex.items-center.rounded-full.bg-indigo-100.px-2.5.py-0.5.text-xs.font-semibold.text-indigo-800= @redis_info[:current_db]
          .flex.flex-wrap.items-start.gap-2
            %span.font-medium.text-gray-700 DB occupancy:
            .flex.flex-wrap.gap-1
              - (0..15).each do |db|
                - in_use = @redis_info[:used_dbs].include?(db)
                - is_current = db == @redis_info[:current_db]
                - badge_class = is_current ? "bg-indigo-600 text-white" : in_use ? "bg-amber-100 text-amber-800 border border-amber-300" : "bg-green-100 text-green-800 border border-green-300"
                %span.inline-flex.items-center.rounded.px-2.py-0.5.text-xs.font-mono{ class: badge_class }
                  = db
                  - if is_current
                    %span.ml-1 ★
                  - elsif in_use
                    %span.ml-1 (in use)

    .mt-6.flex.items-center.gap-2.border-t.border-gray-200.pt-4
      = f.submit "Save integration", class: "px-4 py-2 rounded bg-indigo-600 text-white hover:bg-indigo-700 cursor-pointer"
