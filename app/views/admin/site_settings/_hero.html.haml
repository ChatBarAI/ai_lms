%section{ id: "hero", class: "scroll-mt-24", data: { site_settings_section: "hero" } }
  = form_with model: @site_setting, url: admin_site_setting_path, method: :patch, data: { turbo: false }, class: "rounded-xl border border-gray-200 bg-white p-6 shadow-sm" do |f|
    = hidden_field_tag :section, "hero"

    %h2.text-lg.font-semibold.text-gray-900 Home page hero
    %p.text-sm.text-gray-500 Copy and format for the homepage banner.

    = render "section_errors", section: "hero"

    .mt-5.grid.grid-cols-1.gap-5
      %div
        = f.label :hero_content_format, "Format", class: "block text-sm font-medium mb-1"
        .flex.gap-4
          - SiteSetting::HERO_CONTENT_FORMATS.each do |fmt|
            %label.inline-flex.items-center.gap-2.text-sm
              = f.radio_button :hero_content_format, fmt, class: "rounded border-gray-300"
              %span.capitalize= fmt

      %div
        = f.label :hero_content, "Content", class: "block text-sm font-medium mb-1"
        = f.text_area :hero_content, rows: 6, class: "w-full border border-gray-300 rounded px-3 py-2 font-mono text-sm", placeholder: "Leave blank to show the default heading"

    .mt-6.flex.items-center.gap-2.border-t.border-gray-200.pt-4
      = f.submit "Save hero content", class: "px-4 py-2 rounded bg-indigo-600 text-white hover:bg-indigo-700 cursor-pointer"
