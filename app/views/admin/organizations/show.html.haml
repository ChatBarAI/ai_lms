- content_for :title, @organization.name

.flex.items-center.justify-between.mb-4
  %div
    %h1.text-2xl.font-bold= @organization.name
    .text-sm.text-gray-500= @organization.contact_email
  .flex.gap-2
    = link_to "Edit", edit_admin_organization_path(@organization), class: "px-3 py-1.5 rounded bg-gray-100 text-gray-800 hover:bg-gray-200 border border-gray-200 text-sm"
    = button_to "Delete", admin_organization_path(@organization), method: :delete, data: { turbo_confirm: "Delete #{@organization.name}?" }, class: "px-3 py-1.5 rounded bg-red-100 text-red-800 hover:bg-red-200 border border-red-200 text-sm cursor-pointer"

.grid.grid-cols-2.md:grid-cols-4.gap-3.mb-6
  - tiles = [ [ "Users", @users.size ], [ "Enrolments", @total_enrollments ], [ "Completions", @completions ], [ "Completion rate", "#{@completion_rate}%" ] ]
  - tiles.each do |label, value|
    .bg-white.border.border-gray-200.rounded.p-3
      .text-xs.uppercase.tracking-wide.text-gray-500= label
      .text-2xl.font-semibold.mt-1= value

.grid.grid-cols-1.lg:grid-cols-2.gap-4.mb-6
  .bg-white.border.border-gray-200.rounded.p-4
    %h2.font-semibold.mb-2 Enrolments per week (12w)
    = svg_chart @enrollments_per_week, type: :column, color: "#0ea5e9"
  .bg-white.border.border-gray-200.rounded.p-4
    %h2.font-semibold.mb-2 Completions per week (12w)
    = svg_chart @completions_per_week, type: :column, color: "#16a34a"

.bg-white.border.border-gray-200.rounded.mb-6
  .px-4.py-2.border-b.border-gray-100.font-semibold Notes
  .px-4.py-3.text-sm.text-gray-700.whitespace-pre-wrap= @organization.notes.presence || "—"

.bg-white.border.border-gray-200.rounded.mb-6
  .px-4.py-2.border-b.border-gray-100.flex.items-center.justify-between
    %span.font-semibold Enterprise SSO
    = link_to "Edit", edit_admin_organization_path(@organization), class: "text-xs text-indigo-600 hover:underline"
  .px-4.py-3.text-sm
    - if @organization.sso_configured?
      - app_url = SiteSetting.current.app_url.presence || "https://your-domain.com"
      .grid.grid-cols-1.gap-2
        .flex.gap-3
          %span.text-gray-500.w-32 Provider
          %span= @organization.kinde_connection_provider&.capitalize
        .flex.gap-3
          %span.text-gray-500.w-32 Connection ID
          %code.font-mono.text-xs.bg-gray-50.border.border-gray-200.rounded.px-2.py-0.5= @organization.kinde_connection_id
        .flex.gap-3
          %span.text-gray-500.w-32 Auto-enrol
          %span= @organization.sso_auto_enroll? ? "Yes" : "No"
        .flex.gap-3
          %span.text-gray-500.w-32 SSO required
          - if @organization.sso_required?
            %span.inline-flex.items-center.gap-1.px-2.py-0.5.rounded-full.text-xs.font-medium.bg-amber-100.text-amber-800.border.border-amber-200 Enforced
          - else
            %span.text-gray-400 Optional
        .flex.gap-3
          %span.text-gray-500.w-32 Email domain
          %span= @organization.sso_domain.presence || "—"
        .flex.gap-3.items-start
          %span.text-gray-500.w-32 Sign-in URL
          .flex-1
            %code.block.bg-gray-50.border.border-gray-200.rounded.px-2.py-0.5.text-xs.break-all= @organization.sso_login_url(app_url)
            %p.text-xs.text-gray-400.mt-1 Share with the client's staff to bookmark.
    - else
      .text-gray-500 Not configured.
      = link_to "Set up SSO →", edit_admin_organization_path(@organization), class: "text-indigo-600 hover:underline text-sm"

.bg-white.border.border-gray-200.rounded
  .px-4.py-2.border-b.border-gray-100.font-semibold Members
  - if @users.any?
    %table.w-full.text-sm
      %thead.bg-gray-50
        %tr
          %th.text-left.text-xs.font-medium.text-gray-500.px-3.py-2 Email
          %th.text-left.text-xs.font-medium.text-gray-500.px-3.py-2 Role
          %th.text-right.text-xs.font-medium.text-gray-500.px-3.py-2 Enrol.
          %th.text-right.text-xs.font-medium.text-gray-500.px-3.py-2 Done
          %th.text-left.text-xs.font-medium.text-gray-500.px-3.py-2 Last sign-in
      %tbody
        - @users.each do |u|
          %tr.border-t.border-gray-100
            %td.px-3.py-2= link_to u.email, admin_user_path(u), class: "text-indigo-600 hover:underline"
            %td.px-3.py-2= u.role
            %td.px-3.py-2.text-right= u.enrollments.size
            %td.px-3.py-2.text-right= u.completed_lessons_count
            %td.px-3.py-2.text-gray-500= u.last_sign_in_at&.strftime("%Y-%m-%d") || "—"
  - else
    .px-4.py-3.text-sm.text-gray-500 No members yet.
