- content_for :title, "Organizations"

.flex.items-center.justify-between.mb-4
  %h1.text-2xl.font-bold Organizations
  = link_to "New organization", new_admin_organization_path, class: "inline-flex items-center px-3 py-1.5 rounded-full text-sm font-medium bg-indigo-600 text-white hover:bg-indigo-700"

- if @organizations.any?
  .overflow-x-auto.bg-white.border.border-gray-200.rounded
    %table.w-full.text-sm
      %thead.bg-gray-50
        %tr
          %th.text-left.text-xs.font-medium.text-gray-500.px-3.py-2 Name
          %th.text-left.text-xs.font-medium.text-gray-500.px-3.py-2 Slug
          %th.text-left.text-xs.font-medium.text-gray-500.px-3.py-2 Contact
          %th.text-left.text-xs.font-medium.text-gray-500.px-3.py-2 SSO
          %th.text-right.text-xs.font-medium.text-gray-500.px-3.py-2 Users
          %th.text-right.text-xs.font-medium.text-gray-500.px-3.py-2 Completion
          %th.text-right.text-xs.font-medium.text-gray-500.px-3.py-2
      %tbody
        - @organizations.each do |org|
          %tr.border-t.border-gray-100
            %td.px-3.py-2.font-medium= link_to org.name, admin_organization_path(org), class: "text-indigo-600 hover:underline"
            %td.px-3.py-2.text-gray-500= org.slug
            %td.px-3.py-2.text-gray-600= org.contact_email || "—"
            %td.px-3.py-2
              - if org.sso_configured?
                %span.inline-flex.items-center.gap-1.px-2.py-0.5.rounded-full.text-xs.font-medium.bg-green-100.text-green-800.border.border-green-200
                  = org.kinde_connection_provider&.capitalize || "SSO"
              - else
                %span.text-gray-400 —
            %td.px-3.py-2.text-right= org.users_count
            %td.px-3.py-2.text-right #{org.completion_rate}%
            %td.px-3.py-2.text-right
              .flex.justify-end.gap-2
                = link_to "Edit", edit_admin_organization_path(org), class: "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 hover:bg-gray-200 border border-gray-200"
                = button_to "Delete", admin_organization_path(org), method: :delete, data: { turbo_confirm: "Delete?" }, class: "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800 hover:bg-red-200 border border-red-200 cursor-pointer"
- else
  .bg-white.border.border-gray-200.rounded.p-6.text-center.text-gray-500
    No organizations yet.
    = link_to "Create the first one", new_admin_organization_path, class: "text-indigo-600 hover:underline"
