- content_for :title, t(".title", **terms)

%h1.text-2xl.font-bold.mb-4= terms[:subjects]

.grid.grid-cols-1.sm:grid-cols-2.md:grid-cols-3.gap-4
  - @subjects.each do |subject|
    = link_to subject_path(subject), class: "block bg-white border border-gray-200 rounded-lg p-4 hover:border-indigo-300" do
      %h3.font-semibold= subject.name
      %p.text-sm.text-gray-500.mt-1
        = t(".courses_count", count: subject.courses.count, **terms)
      - if subject.description.present?
        %p.text-sm.text-gray-600.mt-2.line-clamp-2= subject.description
