- content_for :title, @subject.name

.mb-4.flex.items-center.justify-between
  %h1.text-2xl.font-bold= @subject.name
  = link_to subjects_path, class: "inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-700 hover:bg-indigo-100 hover:text-indigo-700 transition-colors" do
    ← Subjects
- if @subject.description.present?
  %p.text-gray-600.mb-6= @subject.description

%h2.text-lg.font-semibold.mb-3 Courses
- if @courses.any?
  .grid.grid-cols-1.sm:grid-cols-2.gap-4
    - @courses.each do |course|
      = render "courses/card", course: course, hide_subject: true
- else
  %p.text-gray-500 No published courses in this subject yet.
