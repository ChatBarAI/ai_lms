- content_for :title, "Certificate Verification"

.max-w-xl.mx-auto.py-12

  .bg-white.border.border-gray-200.rounded-lg.p-8.text-center.shadow-sm
    .text-5xl.mb-4 ✓
    %h1.text-xl.font-bold.text-gray-900.mb-1 Certificate Verified
    %p.text-sm.text-gray-500.mb-6 This certificate is authentic and was issued by #{SiteSetting.current.brand_name.presence || "this platform"}.

    %dl.text-left.divide-y.divide-gray-100.text-sm
      %div.flex.justify-between.py-2
        %dt.text-gray-500 Recipient
        %dd.font-medium.text-gray-900= @user.name.presence || @user.email
      %div.flex.justify-between.py-2
        %dt.text-gray-500 Course
        %dd.font-medium.text-gray-900= @course.title
      %div.flex.justify-between.py-2
        %dt.text-gray-500 Issued on
        %dd.font-medium.text-gray-900= l(@certificate.issued_at.to_date, format: :long)
      %div.flex.justify-between.py-2
        %dt.text-gray-500 Certificate No.
        %dd.font-mono.text-gray-600= @certificate.token

  .mt-6.text-center
    = link_to "Go to homepage", root_path, class: "text-sm text-indigo-600 hover:underline"
