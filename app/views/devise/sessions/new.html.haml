.max-w-md.mx-auto
  %h1.text-2xl.font-semibold.mb-6= t("devise.views.sessions.new.heading")
  = form_for(resource, as: resource_name, url: session_path(resource_name)) do |f|
    .mb-4
      = f.label :email, class: "block text-sm font-medium text-gray-700 mb-1"
      = f.email_field :email, autofocus: true, autocomplete: "email",
          data: { sso_check_url: sso_check_path },
          class: "block w-full rounded border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none"
      #sso-redirect-notice.hidden.mt-2.text-sm.text-amber-700
    .mb-4
      = f.label :password, class: "block text-sm font-medium text-gray-700 mb-1"
      = f.password_field :password, autocomplete: "current-password", class: "block w-full rounded border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none"
    - if devise_mapping.rememberable?
      .mb-4
        = toggle_switch_field f, :remember_me, label: t("devise.views.sessions.new.remember_me")
    .mb-4
      = f.submit t("devise.views.sessions.new.submit"), class: "w-full inline-flex justify-center px-4 py-2 rounded bg-indigo-600 text-white font-medium hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 cursor-pointer"
  = render "devise/shared/links"

:javascript
  (function () {
    const emailField = document.querySelector('[data-sso-check-url]');
    if (!emailField) return;
    const checkUrl = emailField.dataset.ssoCheckUrl;
    const notice = document.getElementById('sso-redirect-notice');
    let debounce;

    emailField.addEventListener('blur', function () {
      clearTimeout(debounce);
      const email = emailField.value.trim();
      if (!email.includes('@')) return;

      fetch(checkUrl + '?email=' + encodeURIComponent(email), {
        headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }
      })
      .then(r => r.json())
      .then(data => {
        if (data.sso_url) {
          notice.textContent = #{t("devise.views.sessions.new.sso_redirecting").to_json};
          notice.classList.remove('hidden');
          window.location.href = data.sso_url;
        }
      })
      .catch(() => {}); // silently ignore network errors
    });
  })();
