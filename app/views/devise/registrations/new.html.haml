.max-w-md.mx-auto
  %h1.text-2xl.font-semibold.mb-6= t("devise.views.registrations.new.heading")
  = form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f|
    = render "devise/shared/error_messages", resource: resource
    .mb-4
      = f.label :email, class: "block text-sm font-medium text-gray-700 mb-1"
      = f.email_field :email, autofocus: true, autocomplete: "email", class: "block w-full rounded border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none"
    .mb-4
      = f.label :password, class: "block text-sm font-medium text-gray-700 mb-1"
      - if @minimum_password_length
        %span.text-xs.text-gray-500
          = t("devise.views.registrations.new.minimum_password_length", count: @minimum_password_length)
      = f.password_field :password, autocomplete: "new-password", class: "block w-full rounded border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none"
    .mb-4
      = f.label :password_confirmation, class: "block text-sm font-medium text-gray-700 mb-1"
      = f.password_field :password_confirmation, autocomplete: "new-password", class: "block w-full rounded border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none"
    .mb-4
      = f.submit t("devise.views.registrations.new.submit"), class: "w-full inline-flex justify-center px-4 py-2 rounded bg-indigo-600 text-white font-medium hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 cursor-pointer"
  = render "devise/shared/links"
