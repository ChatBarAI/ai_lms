.max-w-md.mx-auto
  %h1.text-2xl.font-semibold.mb-6 Change your password
  = form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f|
    = render "devise/shared/error_messages", resource: resource
    = f.hidden_field :reset_password_token
    .mb-4
      = f.label :password, "New password", class: "block text-sm font-medium text-gray-700 mb-1"
      - if @minimum_password_length
        %span.text-xs.text-gray-500
          = "(#{@minimum_password_length} characters minimum)"
      = f.password_field :password, autofocus: true, autocomplete: "new-password", class: "block w-full rounded border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none"
    .mb-4
      = f.label :password_confirmation, "Confirm new password", class: "block text-sm font-medium text-gray-700 mb-1"
      = f.password_field :password_confirmation, autocomplete: "new-password", class: "block w-full rounded border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none"
    .mb-4
      = f.submit "Change my password", class: "w-full inline-flex justify-center px-4 py-2 rounded bg-indigo-600 text-white font-medium hover:bg-indigo-700 cursor-pointer"
  = render "devise/shared/links"
