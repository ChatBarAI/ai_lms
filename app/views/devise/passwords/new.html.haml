.max-w-md.mx-auto
  %h1.text-2xl.font-semibold.mb-6 Forgot your password?
  - sso_org = current_user&.organization || (@email_hint && Organization.for_email_domain(@email_hint))
  - if sso_org&.sso_required?
    .bg-amber-50.border.border-amber-200.rounded.p-4.mb-4.text-sm
      %p
        %strong= sso_org.name
        uses single sign-on. Password reset is not available for SSO accounts.
      - app_url = SiteSetting.current.app_url.presence || "#{request.scheme}://#{request.host_with_port}"
      = link_to "Sign in via #{sso_org.name} SSO →", sso_org.sso_login_url(app_url), class: "mt-2 inline-block text-indigo-600 hover:underline"
  - else
    = form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f|
      = render "devise/shared/error_messages", resource: resource
      .mb-4
        = f.label :email, class: "block text-sm font-medium text-gray-700 mb-1"
        = f.email_field :email, autofocus: true, autocomplete: "email", class: "block w-full rounded border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none"
      .mb-4
        = f.submit "Send me reset password instructions", class: "w-full inline-flex justify-center px-4 py-2 rounded bg-indigo-600 text-white font-medium hover:bg-indigo-700 cursor-pointer"
  = render "devise/shared/links"
