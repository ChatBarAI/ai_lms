- if answers.present?
  .bg-white.border.border-gray-200.rounded-lg.p-4.mb-6{ id: "quiz-results", data: { controller: "collapsible", expanded: "false" } }
    .flex.flex-wrap.items-start.justify-between.gap-3
      .min-w-0.flex-1
        %h2.text-lg.font-semibold Latest #{terms[:quiz]} results
        %p.text-sm.text-gray-500= "Score: #{progress.score.to_f.round(1)}% · Pass mark: #{lesson.effective_pass_mark}%"
      .flex.items-center.gap-2
        - if progress.completed?
          %span.inline-flex.items-center.rounded-full.border.border-green-200.bg-green-50.px-2.5.py-1.text-xs.font-medium.text-green-700 Passed
        - else
          %span.inline-flex.items-center.rounded-full.border.border-amber-200.bg-amber-50.px-2.5.py-1.text-xs.font-medium.text-amber-700 Needs practice
        %button{ type: "button", class: "inline-flex", data: { action: "click->collapsible#toggle" }, "aria-label": "Toggle latest #{terms[:quiz_l]} results" }
          = collapsible_icon_badge

    .space-y-3.mt-4.hidden{ data: { collapsible_target: "content" } }
      - answers.each_with_index do |answer, idx|
        - question = answer.question
        - result = quiz_answer_result(answer, lesson)
        - show_expected_answer = quiz_answer_correct?(answer, lesson)
        .rounded-lg.border.border-gray-200.p-3
          .flex.flex-wrap.items-start.justify-between.gap-2
            .min-w-0.flex-1.flex.items-start.gap-3
              %span.inline-flex.h-7.min-w-7.shrink-0.items-center.justify-center.rounded-full.bg-slate-100.text-xs.font-semibold.text-indigo-700.ring-1.ring-slate-200= idx + 1
              %p.font-medium.text-gray-900= question.prompt
            %span.inline-flex.shrink-0.items-center.rounded-full.border.px-2.5.py-1.text-xs.font-medium{ class: result[:classes] }= result[:label]
          .mt-3.grid.gap-3.md:grid-cols-2
            %div
              %p.text-xs.font-semibold.uppercase.text-gray-500 Your answer
              %p.mt-1.text-sm.text-gray-800.whitespace-pre-wrap= answer.answer_text.presence || "No answer submitted"
            - if show_expected_answer
              %div
                %p.text-xs.font-semibold.uppercase.text-gray-500= question.free_text? ? "Model answer" : "Correct answer"
                %p.mt-1.text-sm.text-gray-800.whitespace-pre-wrap= question.correct_answer.presence || "Not provided"
