- total = questions.size
.bg-white.border.border-gray-200.rounded-lg.p-2.sm:p-4.mb-6{ data: { controller: "quiz-single collapsible", expanded: (collapsed ? "false" : "true"), action: "collapsible:expanded->quiz-single#onExpanded collapsible:collapsed->quiz-single#onCollapsed", quiz_single_hide_progress_while_collapsed_value: (collapsed ? "true" : "false") } }
  .flex.items-center.justify-between
    %h3.font-semibold= terms[:quiz]
    .flex.items-center.gap-3
      - if retry_mode
        %span.text-xs.font-medium.px-2.py-0.5.rounded-full.bg-amber-100.text-amber-700 Retry mode
      %span.text-sm.text-gray-600.font-medium{ class: (collapsed ? "hidden" : nil), data: { quiz_single_target: "counter" } }
        Question
        %span{ data: { quiz_single_target: "currentIndex" } } 1
        of #{total}
      .flex.gap-1
        %button.px-2.py-1.rounded.border.border-gray-300.text-gray-600.font-bold.hover:text-gray-900.hover:bg-gray-100.hover:border-gray-400.disabled:opacity-30.disabled:cursor-not-allowed.transition-colors{ type: "button", data: { action: "click->quiz-single#prev", quiz_single_target: "prevBtn" }, "aria-label": "Previous question" }
          ←
        %button.px-2.py-1.rounded.border.border-gray-300.text-gray-600.font-bold.hover:text-gray-900.hover:bg-gray-100.hover:border-gray-400.disabled:opacity-30.disabled:cursor-not-allowed.transition-colors{ type: "button", data: { action: "click->quiz-single#next", quiz_single_target: "nextBtn" }, "aria-label": "Next question" }
          →
      %button{ type: "button", class: "inline-flex", data: { action: "click->collapsible#toggle" }, "aria-label": "Toggle #{terms[:quiz_l]}" }
        = collapsible_icon_badge

  %div.mt-5{ data: { collapsible_target: "content" } }
    = form_with url: submit_quiz_course_lesson_path(lesson.course, lesson), method: :post, local: true, data: { turbo: false } do |f|
      .overflow-hidden.duration-300{ class: "transition-[height]", data: { quiz_single_target: "viewport" } }
        .flex.items-start{ style: "transition: transform 0.35s ease-in-out;", data: { quiz_single_target: "track" } }
          - questions.each_with_index do |q, idx|
            .flex-shrink-0.w-full{ data: { quiz_single_target: "slide", question_id: q.id } }
              .border.border-gray-200.rounded-lg.p-2.sm:p-4
                .flex.items-start.gap-3
                  .hidden.sm:flex.w-7.h-7.rounded-full.bg-indigo-600.items-center.justify-center.text-xs.font-semibold.text-white.flex-shrink-0
                    = idx + 1
                  .flex-1
                    %span.float-left.inline-flex.items-center.justify-center.min-w-7.h-7.rounded-full.bg-indigo-600.text-xs.font-semibold.text-white.mr-2.mb-1.sm:hidden
                      = idx + 1
                    .bg-slate-50.rounded-lg.mb-3.flow-root{ class: "dark:bg-slate-800/70" }
                      - if lesson.cbai_enabled?
                        - eail = "I am completing the LMS lesson called #{lesson.title}. Provide me with the information required to answer this question: #{q.prompt}"
                        %button.float-right.inline-flex.items-center.gap-1.5.px-2.5.py-1.rounded.bg-indigo-600.text-white.hover:bg-indigo-700.cursor-pointer.text-xs.transition-colors.ml-3.mb-2{ type: "button", tabindex: "-1", onclick: "var r=document.getElementById('cbai_launcher_#{lesson.id}');if(r&&r._cbaiOpenWithEail)r._cbaiOpenWithEail(this.dataset.cbaiEail);", data: { cbai_eail: eail } }
                          = site_favicon_img_tag
                          Ask AI tutor
                      %p.font-medium.text-slate-900.dark:text-slate-100= q.prompt
                    - if q.multiple_choice?
                      %p.text-xs.font-semibold.tracking-wide.uppercase.text-slate-500.dark:text-slate-400.mb-2 Answer choices
                      .flex.flex-wrap.gap-2
                        - q.choices_list.each do |choice|
                          %label.inline-flex.flex-auto.max-w-full.items-center.justify-center.text-center.leading-snug.px-4.py-2.5.rounded-lg.border.border-slate-300.bg-white.cursor-pointer.transition-all.text-sm.font-medium.select-none.hover:border-indigo-300.hover:bg-indigo-50.hover:text-gray-900{ class: "min-w-[4.5rem] has-[:checked]:border-indigo-500 has-[:checked]:bg-indigo-500/20 has-[:checked]:text-indigo-700" }
                            %input.sr-only{ type: "radio", name: "answers[#{q.id}]", value: choice, data: { action: "change->quiz-single#radioChanged" } }
                            = choice
                    - elsif q.true_false?
                      %p.text-xs.font-semibold.tracking-wide.uppercase.text-slate-500.dark:text-slate-400.mb-2 Answer choices
                      .grid.grid-cols-2.gap-2.max-w-sm
                        - %w[true false].each do |val|
                          %label.inline-flex.w-full.items-center.justify-center.px-4.py-2.5.rounded-lg.border.border-slate-300.bg-white.cursor-pointer.transition-all.text-sm.font-medium.select-none.hover:border-indigo-300.hover:bg-indigo-50.hover:text-gray-900{ class: "has-[:checked]:border-indigo-500 has-[:checked]:bg-indigo-500/20 has-[:checked]:text-indigo-700" }
                            %input.sr-only{ type: "radio", name: "answers[#{q.id}]", value: val, data: { action: "change->quiz-single#radioChanged" } }
                            = val.capitalize
                    - else
                      .flex.gap-2.items-start
                        %textarea.flex-1.min-h-10.border.border-gray-300.rounded-lg.px-3.py-2.text-sm.resize-none.overflow-hidden.leading-5{ name: "answers[#{q.id}]", rows: "1", placeholder: "Type your answer...", data: { controller: "auto-grow-textarea", auto_grow_textarea_target: "field", free_text_answer: true, action: "input->auto-grow-textarea#resize" } }
                        %button.px-3.py-2.rounded-lg.bg-indigo-600.text-white.text-sm.font-medium.hover:bg-indigo-700.transition-colors{ type: "button", data: { action: "click->quiz-single#textNext keydown->quiz-single#tabAdvance" } }= idx == questions.size - 1 ? "Done ✓" : "Next →"
                %span.flex-shrink-0.text-green-500.font-medium.text-sm.hidden{ data: { checkmark: true } } ✓

      .mt-6.pt-4.border-t.border-gray-100.hidden{ data: { quiz_single_target: "submitContainer" } }
        .rounded-lg.bg-green-50.border.border-green-300.p-4.flex.items-center.justify-between.gap-3
          %p.text-sm.text-green-800.font-medium
            ✓ All questions answered — ready to submit!
          = f.submit "Submit answers →", class: "px-5 py-2.5 rounded-lg bg-green-600 text-white font-semibold cursor-pointer hover:bg-green-700 transition-colors shadow-sm", data: { quiz_single_target: "submit" }
