- index = local_assigns.fetch(:index, nil)
- enrollment = local_assigns.fetch(:enrollment, nil)
- queued_for_marking_lesson_ids = local_assigns.fetch(:queued_for_marking_lesson_ids, [])
- show_course_info = local_assigns.fetch(:show_course_info, true)

= link_to course_lesson_path(lesson.course, lesson), class: "block h-full bg-white border border-gray-200 rounded-lg overflow-hidden hover:border-indigo-300 dark:bg-gray-800 dark:border-gray-700 dark:hover:border-indigo-500" do
  .relative
    - if lesson.cover_image.attached?
      = image_tag lesson.cover_image, class: "w-full h-40 object-cover"
    - else
      = default_meta_card_image_tag(class: "w-full h-40 object-cover")
    - if lesson.duration_minutes.present?
      .absolute.top-2.right-2.flex.items-center.gap-1.bg-black.bg-opacity-60.text-white.text-xs.font-medium.rounded-full.px-2.py-1
        = image_tag "clock.png", alt: "", class: "w-3 h-3 invert"
        = t(".duration", count: lesson.duration_minutes)
    - if lesson.tags.any?
      .absolute.bottom-2.right-2.flex.flex-wrap.justify-end.gap-1
        - lesson.tags.each do |tag|
          %span.inline-flex.items-center.px-3.py-1.rounded-full.text-xs.font-medium{ style: "background-color: #{tag.color}; color: #{tag.text_color}" }= tag.name
  .p-4
    .flex.items-start.justify-between.gap-2.mb-1
      %h3.font-semibold.leading-snug= "#{index ? "#{index}. " : ""}#{lesson.title}"
      .flex.shrink-0.gap-1
        - unless lesson.published?
          %span.text-xs.text-amber-600= t("common.draft")
        - if enrollment
          - progress = enrollment.progresses.find { |p| p.lesson_id == lesson.id }
          - if progress&.completed?
            %span.text-xs.text-green-700= t(".done")
          - elsif progress&.in_progress?
            - if queued_for_marking_lesson_ids.include?(lesson.id)
              %span.text-xs.text-indigo-700= t(".queued_for_marking")
            - else
              %span.text-xs.text-indigo-700= t(".in_progress")
    - if show_course_info
      %p.text-sm.text-gray-500.mt-1= subjects_enabled? && lesson.course.subject ? "#{lesson.course.title} · #{lesson.course.subject.name}" : lesson.course.title
    - if lesson.body.present?
      %p.text-sm.text-gray-600.mt-2.line-clamp-2.dark:text-gray-400= lesson.body.to_plain_text
