.bg-white.border.border-gray-200.rounded-lg.p-4.mb-6
  %h3.font-semibold.mb-3 Rate this lesson
  - rating = user_rating || Rating.new
  - method = rating.persisted? ? :patch : :post
  - url = rating.persisted? ? course_lesson_rating_path(lesson.course, lesson, rating) : course_lesson_ratings_path(lesson.course, lesson)
  = form_with model: rating, url: url, method: method, local: true, class: "space-y-3" do |f|
    .flex.items-start.gap-3
      .flex.flex-col.gap-1.shrink-0
        %label.block.text-sm.font-medium Stars (optional)
        = f.select :stars, (1..5).map { |n| [ "#{n} ★", n ] }, { include_blank: "—" }, class: "border border-gray-300 rounded px-2 py-1"
        - if rating.persisted?
          = button_to "Remove rating", course_lesson_rating_path(lesson.course, lesson, rating), method: :delete, data: { turbo_confirm: "Remove your rating?" }, class: "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700 hover:bg-red-200 cursor-pointer transition-colors border-0 mt-1"
      .flex-1
        %label.block.text-sm.font-medium.mb-1 Comment (optional)
        = f.text_area :comment, rows: 2, class: "w-full border border-gray-300 rounded px-3 py-2"
    = f.submit (rating.persisted? ? "Update rating" : "Submit rating"), class: "w-full px-3 py-1.5 rounded bg-indigo-600 text-white hover:bg-indigo-700 cursor-pointer text-sm mt-3"
