- content_for :title, @lesson.title

.mb-4.flex.items-center.justify-end{ data: { controller: "lesson-show" } }
  .flex.flex-wrap.gap-2.items-center
    = link_to course_path(@course), class: "inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-700 hover:bg-indigo-100 hover:text-indigo-700 transition-colors" do
      ← Course
    - if can?(:update, @lesson)
      - if @lesson.published?
        = button_to t("common.unpublish"), unpublish_course_lesson_path(@course, @lesson), method: :post, data: { turbo_confirm: t(".unpublish_confirm", **terms) }, class: "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800 hover:bg-amber-200 cursor-pointer transition-colors"
      - else
        = button_to t("common.publish_now"), publish_course_lesson_path(@course, @lesson), method: :post, class: "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-600 text-white hover:bg-green-700 cursor-pointer transition-colors"
      = link_to t(".edit", **terms), edit_course_lesson_path(@course, @lesson), class: "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 hover:bg-gray-200 border border-gray-200 transition-colors"
      = link_to t(".questions"), course_lesson_questions_path(@course, @lesson), class: "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 hover:bg-gray-200 border border-gray-200 transition-colors"

.bg-white.border.border-gray-200.rounded-lg.p-2.sm:p-6.mb-6.flow-root
  - poster_url = (@lesson.poster_image.attached? ? rails_blob_path(@lesson.poster_image) : nil)
  - if @lesson.intro_video.attached?
    %video.w-full.mb-6.rounded-lg.border.border-gray-200{ controls: true, preload: "metadata", poster: poster_url }
      %source{ src: rails_blob_path(@lesson.intro_video, disposition: "inline"), type: @lesson.intro_video.content_type }
  - elsif (video = lesson_video_embed(@lesson.video_url, poster_url: poster_url))
    = video

  - if @lesson.cover_image.attached?
    = image_tag @lesson.cover_image, class: "w-full sm:float-right sm:ml-4 sm:w-auto sm:max-w-96 object-contain mb-4 sm:mb-2"
  .flex.items-center.gap-4.mb-4
    %h1.text-2xl.font-bold= @lesson.title
    = render "shared/tags", record: @lesson

  - if @lesson.body.present?
    .prose.max-w-none= @lesson.body
  - else
    %p.text-gray-400.italic= t(".no_content")

- if @lesson.anam_enabled? && @anam_session_token.present?
  = render "anam_embed", lesson: @lesson, session_token: @anam_session_token
- elsif @lesson.cbai_enabled?
  = render "cbai_embed", lesson: @lesson
- elsif @lesson.custom_tutor_enabled?
  = render "custom_tutor_embed", lesson: @lesson

- if @lesson.lesson_materials.any?
  #lesson-materials.mb-6
    %h2.text-lg.font-semibold.mb-3 Materials
    - @lesson.lesson_materials.each do |m|
      = render "lesson_materials/material", material: m, course: @course, lesson: @lesson, enrollment: @enrollment

- if @enrollment
  .bg-white.border.border-gray-200.rounded-lg.p-4.mb-6{ id: "lesson-status" }
    - status_chart_dialog_id = "status-chart-dialog-#{@progress.id}"
    .flex.items-stretch.gap-4
      = lesson_progress_ring(@progress, classes: "self-center shrink-0")
      .flex.items-stretch.gap-4
        .min-w-0.flex-1.flex.items-stretch.gap-3
          .min-w-0.flex-1
            .flex.items-center.gap-2
              %p.font-semibold.text-sm= t(".status", status: @progress.status.to_s.humanize)
            - if @ai_scoring_pending
              .flex.items-center.gap-1.5.mt-0.5{ data: { controller: "scoring-channel", "scoring-channel-progress-id-value": @progress.id } }
                .w-2.h-2.rounded-full.bg-indigo-500.animate-pulse
                %p.text-xs.text-indigo-600.font-medium Queued for marking…
            - elsif @progress.score.present?
              %p.text-xs.text-gray-500= t(".score", score: @progress.score)
            - if @quiz_attempts.present?
              %p.text-xs.text-gray-500.mt-1= "#{terms[:quiz]} attempts: #{@quiz_attempts.count}"
          - if @quiz_attempts.present? && @quiz_attempts.size > 1
            = render "shared/quiz_trend_popup",
                     attempts: @quiz_attempts,
                     pass_mark: @lesson.effective_pass_mark,
                     dialog_id: status_chart_dialog_id,
                     title: "#{terms[:quiz]} Mark Trend",
                     wrapper_class: "shrink-0 self-stretch flex items-stretch pl-2 border-l border-gray-200 relative overflow-visible",
                     button_class: "h-full w-full text-left cursor-zoom-in",
                     mini_width: 180.0,
                     mini_svg_class: "h-full",
                     mini_svg_width: "170",
                     show_attempt_numbers: true,
                     axis_label: "Attempt Number"
      - if !@progress.completed?
        - unless @ai_scoring_pending
          .self-center.ml-auto
            = form_with model: @progress, url: progress_path(@progress.id), method: :patch, local: true do |f|
              = f.hidden_field :status, value: "completed"
              = f.submit t(".mark_complete"), data: { turbo_confirm: t(".confirm_mark_complete") }, class: "px-3 py-1.5 rounded bg-green-600 text-white hover:bg-green-700 cursor-pointer text-sm"
      - else
        .flex.items-center.gap-2.self-center.ml-auto
          %span.text-sm.font-medium.text-green-700= t(".completed")
          - if @enrollment.fully_completed?
            = link_to "Download Certificate", course_certificate_path(@course), class: "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-600 text-white hover:bg-green-700 transition-colors"

  - if @latest_quiz_answers.present?
    = render "latest_quiz_results", lesson: @lesson, progress: @progress, answers: @latest_quiz_answers

- materials_ok = @lesson.lesson_materials_complete_for?(@enrollment)
- if @questions.any? || @retry_mode
  #lesson-quiz
    - if materials_ok
      - if @retry_mode && @questions.empty?
        .bg-green-50.border.border-green-200.text-green-800.rounded.p-4.text-sm.mb-6
          %p.font-semibold ✓ All questions answered correctly — nothing left to retry!
      - elsif !@ai_scoring_pending
        = render "quiz", lesson: @lesson, questions: @questions, progress: @progress, retry_mode: @retry_mode, collapsed: (@enrollment && @progress&.completed?)
    - else
      .bg-amber-50.border.border-amber-200.text-amber-800.rounded.p-4.text-sm.mb-6
        %p.font-semibold.mb-1= "Complete the required materials to unlock the #{terms[:quiz_l]}."
        %p.text-xs= "Mark each required material above as complete, then the #{terms[:quiz_l]} will appear here."

- if @enrollment
  - if @progress.completed? && @lesson.ratings_enabled?
    = render "rating_form", lesson: @lesson, user_rating: @user_rating
- elsif user_signed_in?
  .bg-amber-50.border.border-amber-200.text-amber-800.rounded.p-4.text-sm.flex.items-center.justify-between.gap-3
    %p.flex-1= t(".enrol_prompt", **terms)
    = button_to t(".enrol_now"), course_enrollments_path(@course), method: :post, class: "inline-flex items-center px-3 py-1.5 rounded-full text-sm font-medium bg-amber-500 text-white hover:bg-amber-600 cursor-pointer transition-colors"
