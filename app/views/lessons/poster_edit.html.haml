- content_for :title, "Lesson poster image"

%div
  .mb-4
    = link_to "← Back to lesson edit", edit_course_lesson_path(@course, @lesson), class: "text-sm text-gray-500 hover:text-gray-700"
  %h1.text-2xl.font-bold.mb-2 Poster image
  %p.text-sm.text-gray-500.mb-4 Shown as a thumbnail for the intro video. Learners click the poster to start the video. PNG, JPEG, WEBP or GIF, max 5 MB.

  = form_with model: @lesson, url: poster_course_lesson_path(@course, @lesson), method: :patch, multipart: true, class: "space-y-4 bg-white border border-gray-200 rounded-lg p-6" do |f|
    - if @lesson.errors.any?
      .bg-red-50.border.border-red-200.text-red-800.rounded.p-3.text-sm
        %ul.list-disc.pl-5
          - @lesson.errors.full_messages.each do |msg|
            %li= msg

    %div
      = upload_field f, :poster_image,
          label: "Image file",
          accept: "image/png,image/jpeg,image/webp,image/gif",
          current_attachment: @lesson.poster_image,
          preview_class: "max-w-xs rounded border border-gray-200",
          required: true

    .flex.gap-2
      = f.submit (@lesson.poster_image.attached? ? "Replace poster" : "Upload poster"), class: "px-4 py-2 rounded bg-indigo-600 text-white hover:bg-indigo-700 cursor-pointer"
      = link_to "Cancel", edit_course_lesson_path(@course, @lesson), class: "px-4 py-2 rounded border border-gray-300 hover:bg-gray-50"
