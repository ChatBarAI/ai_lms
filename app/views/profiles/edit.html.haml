- content_for :title, t(".title")

%h1.text-2xl.font-bold.mb-6= t(".heading")

.max-w-lg.bg-white.border.border-gray-200.rounded-lg.p-6
  = form_with model: current_user, url: profile_path, method: :patch, class: "space-y-5" do |f|
    .space-y-1
      = f.label :name, t(".display_name"), class: "block text-sm font-medium text-gray-700"
      = f.text_field :name, class: "block w-full rounded border border-gray-300 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500", placeholder: t(".name_placeholder")
      %p.text-xs.text-gray-500= t(".name_hint")

    .space-y-1
      = f.label :locale, t(".language"), class: "block text-sm font-medium text-gray-700"
      = f.select :locale, User::SUPPORTED_LOCALES.map { |code, label| [label, code] }, {}, class: "block w-full rounded border border-gray-300 px-3 py-2 text-sm bg-white focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500"
      %p.text-xs.text-gray-500= t(".language_hint")

    .space-y-2
      %p.block.text-sm.font-medium.text-gray-700= t(".course_languages")
      .flex.flex-wrap.gap-x-5.gap-y-2
        = hidden_field_tag "user[course_locales][]", ""
        - User::SUPPORTED_LOCALES.each do |code, label|
          %label.flex.items-center.gap-2.text-sm.text-gray-700
            = check_box_tag "user[course_locales][]", code, current_user.course_locales.include?(code), class: "h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500"
            %span= label
      %p.text-xs.text-gray-500= t(".course_languages_hint", courses: terms[:courses_l])

    .space-y-1
      %p.block.text-sm.font-medium.text-gray-700= t(".avatar")
      = upload_field f, :avatar,
          label: t(".avatar_upload"),
          accept: "image/png,image/jpeg,image/gif,image/webp",
          current_attachment: (current_user.avatar.attached? ? current_user.avatar : nil),
          preview_class: "h-24 w-24 rounded-full object-cover border border-gray-200"

    .flex.items-center.gap-3
      = f.submit t(".save"), class: "w-full px-4 py-2 rounded bg-indigo-600 text-white text-sm hover:bg-indigo-700 cursor-pointer"
      = link_to t("common.cancel"), profile_path, class: "inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-700 hover:bg-gray-200 transition-colors"
