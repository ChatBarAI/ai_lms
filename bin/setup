#!/usr/bin/env ruby
require "fileutils"
require "optparse"

APP_ROOT = File.expand_path("..", __dir__)

def system!(*args)
  system(*args, exception: true)
end

options = {}
OptionParser.new do |opts|
  opts.banner = "Usage: bin/setup [options]"
  opts.separator ""
  opts.separator "Sets up the development environment: installs gems, creates and"
  opts.separator "seeds the database, and clears logs and tmp files."
  opts.separator ""
  opts.separator "Options:"

  opts.on("--db-user USER", "PostgreSQL role to use (default: current OS user)") do |user|
    options[:db_user] = user
  end

  opts.on("--admin-email EMAIL", "Admin account email (default: admin@example.com)") do |email|
    options[:admin_email] = email
  end

  opts.on("--admin-name NAME", "Admin display name (default: Admin)") do |name|
    options[:admin_name] = name
  end

  opts.on("--brand-name NAME", "Site brand name (default: ChatBar AI Learn)") do |name|
    options[:brand_name] = name
  end

  opts.on("--app-url URL", "Public app URL, e.g. https://learn.example.com") do |url|
    options[:app_url] = url
  end

  opts.on("-h", "--help", "Show this help message") do
    puts opts
    exit
  end
end.parse!

ENV["PGUSER"]           = options[:db_user]    if options[:db_user]
ENV["SEED_ADMIN_EMAIL"] = options[:admin_email] if options[:admin_email]
ENV["SEED_ADMIN_NAME"]  = options[:admin_name]  if options[:admin_name]
ENV["SEED_BRAND_NAME"]  = options[:brand_name]  if options[:brand_name]
ENV["SEED_APP_URL"]     = options[:app_url]     if options[:app_url]

puts "== Using PostgreSQL user: #{options[:db_user]} ==" if options[:db_user]

# ── System dependency preflight ──────────────────────────────────────────────
FAIL = "\e[31m✗\e[0m"
OK   = "\e[32m✓\e[0m"
WARN = "\e[33m⚠\e[0m"

def check(label, *cmds, required: true)
  found = cmds.any? { |c| system("command -v #{c} > /dev/null 2>&1") }
  if found
    puts "  #{OK}  #{label}"
  elsif required
    puts "  #{FAIL}  #{label}  ← REQUIRED (install and re-run)"
    @preflight_failed = true
  else
    puts "  #{WARN}  #{label}  (optional — needed in production)"
  end
end

puts "\n== Checking system dependencies =="
check "PostgreSQL (psql)",    "psql"
check "libvips (vips)",       "vips"        # ActiveStorage image variants
check "ImageMagick (convert)","convert"     # PWA icon generation
check "Redis (redis-cli)",    "redis-cli",  required: false

if @preflight_failed
  puts "\nAborting: install the missing dependencies above and re-run bin/setup."
  exit 1
end
# ─────────────────────────────────────────────────────────────────────────────

FileUtils.chdir APP_ROOT do
  puts "\n== Installing dependencies =="
  system! "gem install bundler --conservative"
  system("bundle check") || system!("bundle install")

  puts "\n== Preparing database =="
  system! "bin/rails db:prepare"

  puts "\n== Removing old logs and tempfiles =="
  system! "bin/rails log:clear tmp:clear"

  puts "\n== Setup complete! Run 'bin/dev' to start the development server. =="
end
